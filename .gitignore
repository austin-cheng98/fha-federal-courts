# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Secrets (never commit tokens or keys; keep the template)
# ---------------------------------------------------------------------------
config/.cl_token
config/.census_key
*.env

# ---------------------------------------------------------------------------
# Generated outputs / logs
# ---------------------------------------------------------------------------
outputs/
*.log
*.docx

# ---------------------------------------------------------------------------
# Large / regenerable data that must never be committed
# ---------------------------------------------------------------------------
data/external/*.bz2
data/raw/*corpus*.jsonl
data/raw/live_corpus.jsonl
data/processed/synthetic*
# synthetic artifacts regenerated by the tests / `--source synthetic`
data/external/synthetic*
data/raw/synthetic*
data/processed/_synth_truth.json

# derived tables regenerated by run_pipeline / make_paper_assets / analyze_real
# (the three shipped inputs below are kept)
data/processed/case_features.csv
data/processed/real_case_features.csv
data/processed/analysis_panel.csv
data/processed/feii_panel.csv
data/processed/doctrine_map.csv
data/processed/real_doctrine_map.csv
data/processed/doctrine_divergence.csv
data/processed/doctrine_transitions.csv

# Re-include the small data files we DO ship
!data/raw/bulk_fha_cases.jsonl
!data/external/housing_panel.csv
!data/processed/paper_corpus.jsonl
